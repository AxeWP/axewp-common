{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	// Point this to your TS ruleset.
	"extends": "./tsconfig.base.json",

	// Project-specific config.
	"compilerOptions": {
		"noEmit": true,
		"rootDir": ".",
		"baseUrl": ".",
		"typeRoots": [ "./node_modules/@types" ]
	},
	"include": [
		"**/*.json",
		"**/*.cjs",
		"**/*.js",
		"**/*.mjs",
		"**/*.ts",
		"**/*.tsx"
	],
	"exclude": [ "vendor/*", "node_modules/*", "tests/_output/*" ]
}
